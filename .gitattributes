# Force LF line endings for all text files
*.py     text eol=lf
*.pyi    text eol=lf
*.txt    text eol=lf
*.md     text eol=lf
*.rst    text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.toml   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.csv    text eol=lf
*.bat    text eol=crlf
*.cmd    text eol=crlf
